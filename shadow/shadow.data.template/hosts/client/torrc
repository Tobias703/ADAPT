# The "pt client" refers to the instance of tor defined here; the "pt client binary" refers to the rust binary that actually runs the pt

DataDirectory ./ptclient # A place to save our fancy data

# Use the PT
UseBridges 1 # Yes, we want to use a bridge
ClientTransportPlugin foobar exec ../../../../target/debug/pt # Name of the transport and path to the transport binary
Bridge foobar 100.0.0.3:1234 # This speaks the custom protocol, sits inbetween pt client and server binaries

#Port for Connection
SocksPort 0.0.0.0:9052 # The tor client uses this to connect to the pt client

# Disable Conflux (effectively just removes the "just one bridge" warning)
ConfluxEnabled 0

# Log debug file /tmp/tor-client-debug.log
