FROM archlinux:latest

# Install tor
RUN pacman -Sy --noconfirm tor && pacman -Scc --noconfirm

# Create non-root user for tor
RUN useradd -m toruser
USER toruser

WORKDIR /app

# Copy torrc + PT binary
COPY docker/bridge/torrc /app/torrc
COPY --chown=toruser:toruser /shadow/lyrebird /usr/local/bin/lyrebird

# Entrypoint handles the Tor invocation
COPY docker/bridge/entrypoint.sh /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
